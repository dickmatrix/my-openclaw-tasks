# ================== OpenClaw Secure Env Template ==================
# 复制为项目根目录 .env 后再填写。
# 所有敏感值必须手动填写，不要提交到仓库。

# ---- Feishu / Lark (可选，不用可留空) ----
SCOUT_APP_ID=
SCOUT_APP_SECRET=
CENSOR_APP_ID=
CENSOR_APP_SECRET=
WRITER_APP_ID=
WRITER_APP_SECRET=
AUDITOR_APP_ID=
AUDITOR_APP_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# ---- LLM ----
# provider 可填: kimi / deepseek / openai
LLM_PROVIDER=kimi
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ---- Server ----
HOST=0.0.0.0
PORT=8000
OPENCLAW_GATEWAY_TOKEN=

# ---- Optional knobs ----
OPENCLAW_TEMPERATURE_CODE=0.1
OPENCLAW_TEMPERATURE_ARCH=0.6
OPENCLAW_TOP_P_CODE=0.85
OPENCLAW_TOP_P_ARCH=0.95
