# ComfyUI 配置（默认）
# ComfyUI 启动后访问 http://127.0.0.1:8188
SD_API_URL=http://localhost:8188

# 设为 false 使用 SD WebUI (Automatic1111) 模式
COMFYUI_MODE=true

# SD WebUI API Key（如果使用了认证）
SD_API_KEY=

# 输出目录
OUTPUT_DIR=./output_assets

# ============ Itch.io 配置（可选，上传时需要）============

# Itch.io API Key（从 https://itch.io/user/settings/api-keys 获取）
BUTLER_API_KEY=

# Itch.io 用户名
ITCH_USERNAME=

# Itch.io 游戏ID（创建商品后获取）
ITCH_GAME_ID=
